	(text_box "Device Selection Logic (driver side):\nCPU selects devices via /CS lines\nwhich enables the '244. The rotary encoder\nputs the CSn address on the bus for the device\nto match\n\nThis CPU Card has 7 devices that can be selected\ntherefore 7 rotary encoders and a 4 '244 are required"
		(exclude_from_sim no)
		(at 29.21 29.21 0)
		(size 541.02 134.62)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "b46e7996-78b8-4e17-84c1-7cc5ef74ba46")
	)
	(text_box "The CPU PLD Decoder outputs 3 bits to select a device\nThe output is qualified by IO_EN\n\n000 - SIO0\n001 - SIO1\n010 - CTC\n011 - Cartridge IO\n100 - VDP\n101 - Sound\n110 - Controller\n111 - Unused"
		(exclude_from_sim no)
		(at 29.21 165.1 0)
		(size 147.32 138.43)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "f1ccbb53-8b1d-4fed-9259-23d6f32b602e")
	)
